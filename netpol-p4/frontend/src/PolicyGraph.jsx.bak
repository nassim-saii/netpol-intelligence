import { useEffect, useRef, useState } from 'react'
import * as d3 from 'd3'

const NS_COLOR = {
  'online-boutique':'#58a6ff','netpol-system':'#3fb950',
  'llm-system':'#d29922','openshift-monitoring':'#ff7b72',
}

function nsColor(ns, node) {
  if (node.critical > 0) return '#f85149'
  if (node.high > 0) return '#ff7b72'
  return NS_COLOR[ns] || '#8b949e'
}

export default function PolicyGraph() {
  const svgRef = useRef(null)
  const [data, setData] = useState(null)
  const [baseline, setBaseline] = useState([])
  const [loading, setLoading] = useState(true)
  const [selected, setSelected] = useState(null)

  useEffect(() => {
    Promise.all([
      fetch('/api/policy-graph').then(r => r.json()),
      fetch('/api/flow-baseline').then(r => r.json()),
    ]).then(([g,b]) => {
      setData(g); setBaseline(b.baseline||[]); setLoading(false)
    }).catch(e => { console.error(e); setLoading(false) })
  }, [])

  useEffect(() => {
    if (!data || !svgRef.current) return
    const { nodes, edges } = data
    if (!nodes.length) return
    const W = svgRef.current.clientWidth || 700
    const H = 420
    d3.select(svgRef.current).selectAll('*').remove()
    const svg = d3.select(svgRef.current).attr('width',W).attr('height',H)
    const defs = svg.append('defs')
    defs.append('marker').attr('id','arrow').attr('viewBox','0 -4 8 8')
      .attr('refX',16).attr('refY',0).attr('markerWidth',6).attr('markerHeight',6).attr('orient','auto')
      .append('path').attr('d','M0,-4L8,0L0,4').attr('fill','#8b949e')
    const g = svg.append('g')
    svg.call(d3.zoom().scaleExtent([.3,3]).on('zoom', e => g.attr('transform',e.transform)))
    const sim = d3.forceSimulation(nodes)
      .force('link', d3.forceLink(edges).id(d=>d.id).distance(120))
      .force('charge', d3.forceManyBody().strength(-300))
      .force('center', d3.forceCenter(W/2, H/2))
      .force('collision', d3.forceCollide(50))
    const link = g.append('g').selectAll('line').data(edges).join('line')
      .attr('stroke','#30363d').attr('stroke-width', d => Math.max(1,Math.log(d.count+1)))
      .attr('marker-end','url(#arrow)').attr('opacity',.7)
    const node = g.append('g').selectAll('g').data(nodes).join('g').attr('cursor','pointer')
      .call(d3.drag()
        .on('start',(e,d)=>{ if(!e.active) sim.alphaTarget(.3).restart(); d.fx=d.x; d.fy=d.y })
        .on('drag',(e,d)=>{ d.fx=e.x; d.fy=e.y })
        .on('end',(e,d)=>{ if(!e.active) sim.alphaTarget(0); d.fx=null; d.fy=null }))
      .on('click',(e,d)=>setSelected(s=>s?.id===d.id?null:d))
    node.append('circle').attr('r',28)
      .attr('fill', d=>nsColor(d.id,d)).attr('fill-opacity',.15)
      .attr('stroke', d=>nsColor(d.id,d))
      .attr('stroke-width', d=>d.violations>0?2.5:1.5)
    node.append('text').text(d=>d.label.length>12?d.label.slice(0,10)+'…':d.label)
      .attr('text-anchor','middle').attr('dy',4)
      .attr('fill','#e6edf3').attr('font-size',10).attr('pointer-events','none')
    node.append('text').text(d=>d.violations>0?'⚠ '+d.violations:'')
      .attr('text-anchor','middle').attr('dy',-34)
      .attr('fill','#f85149').attr('font-size',10).attr('pointer-events','none')
    sim.on('tick',()=>{
      link.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y)
          .attr('x2',d=>d.target.x).attr('y2',d=>d.target.y)
      node.attr('transform',d=>'translate('+d.x+','+d.y+')')
    })
  }, [data])

  if (loading) return <div className='spinner' />
  if (!data?.nodes?.length) return (
    <div className='card' style={{ textAlign:'center', padding:40, color:'var(--text-muted)' }}>
      <div style={{ fontSize:32, marginBottom:12 }}>🕸️</div>
      No namespace data yet. Audit findings and flow events generate the graph.
    </div>
  )

  return (
    <div>
      <div style={{ display:'flex', alignItems:'center', gap:16, marginBottom:16 }}>
        <h2 style={{ fontWeight:700, fontSize:18 }}>Policy Graph</h2>
        <span style={{ fontSize:12, color:'var(--text-muted)' }}>
          {data.nodes.length} namespaces · {data.edges.length} flow edges · drag to rearrange
        </span>
      </div>
      <div style={{ display:'flex', gap:16 }}>
        <div className='card' style={{ flex:1, padding:0, overflow:'hidden' }}>
          <svg ref={svgRef} style={{ width:'100%', height:420, display:'block' }} />
        </div>
        <div style={{ width:220 }}>
          {selected ? (
            <div className='card'>
              <div style={{ fontWeight:600, marginBottom:8, color:'var(--accent)' }}>{selected.id}</div>
              <div style={{ fontSize:12, color:'var(--text-muted)' }}>
                <div>Violations: <b style={{ color:'var(--text)' }}>{selected.violations}</b></div>
                {selected.critical>0 && <div>Critical: <b style={{ color:'var(--critical)' }}>{selected.critical}</b></div>}
                {selected.high>0 && <div>High: <b style={{ color:'var(--high)' }}>{selected.high}</b></div>}
              </div>
            </div>
          ) : (
            <div className='card'>
              <div style={{ fontSize:11, color:'var(--text-muted)', marginBottom:8 }}>LEGEND</div>
              {[['🔴 Red border','CRITICAL violations'],['🟠 Orange border','HIGH violations'],
                ['🟢 Color fill','Healthy namespace'],['→ Arrow','OVN ACL drop flow']].map(([s,d])=>(
                <div key={s} style={{ fontSize:11, marginBottom:4 }}><b>{s}</b>: {d}</div>
              ))}
            </div>
          )}
          <div className='card' style={{ marginTop:12 }}>
            <div style={{ fontSize:11, color:'var(--text-muted)', marginBottom:8 }}>TOP FLOW KEYS</div>
            {baseline.slice(0,6).map((b,i)=>(
              <div key={i} style={{ marginBottom:6, fontSize:11 }}>
                <div className='mono' style={{ color:'var(--accent)', fontSize:10 }}>{b.flow_key}</div>
                <div style={{ color:'var(--text-muted)' }}>{b.mean_rate.toFixed(1)}/min · n={b.sample_count}</div>
              </div>
            ))}
            {baseline.length===0 && <div style={{ fontSize:11, color:'var(--text-muted)' }}>No baseline data yet</div>}
          </div>
        </div>
      </div>
    </div>
  )
}
